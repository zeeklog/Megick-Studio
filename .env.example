# Megick AI Creations — root .env.example
#
# This file is a shared fallback. Backend-specific values should usually live
# in `apps/api/.env`, `apps/api/.env.development`, or `apps/api/.env.production`.
# Scripts set APP_ENV/NODE_ENV explicitly; avoid pinning NODE_ENV in env files.

# APP_ENV=development

# ----- API server (apps/api) -----

PORT=3001

# AES-256-GCM key for encrypting third-party secrets in the DB.
# Generate with:  openssl rand -base64 32
APP_ENCRYPTION_KEY=

# JWT signing secret (>= 32 chars).
# Generate with:  openssl rand -base64 32
SESSION_SECRET=
SESSION_COOKIE_NAME=mg_session
SESSION_COOKIE_DOMAIN=
SESSION_TTL_SECONDS=2592000

# Initial seeded super admin (used only by `pnpm prisma:seed`)
SUPER_ADMIN_EMAIL=administrator@megick.com
SUPER_ADMIN_PASSWORD=PleaseChangeMe!2026

# Database / Redis
DATABASE_URL="mysql://root:root@127.0.0.1:3306/megick"
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Public URLs
WEB_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:3333
PUBLIC_BASE_URL=http://localhost:8080

# Aliyun OSS (used by ali-oss). Admins can override per asset operation.
OSS_REGION=oss-cn-shenzhen
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
# Custom domain for public OSS access (recommended). Falls back to OSS_PUBLIC_BASE_URL → aliyuncs.com
OSS_DOMAIN=
OSS_PUBLIC_BASE_URL=

# OAuth (fallback; admin /admin/oauth-providers takes precedence at runtime)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Default upstream AI image model (admin can add more in /admin/ai-models)
BPI_TEXT2IMAGE_BASE_URL=https://seedanceapi.org/v2
DEFAULT_AI_TEXT2IMAGE_BASE_URL=https://seedanceapi.org/v2
DEFAULT_AI_TEXT2IMAGE_API_KEY=
GENERATION_DIRECT_TEXT2IMAGE_ORIGINS=https://seedanceapi.org/v2
DEFAULT_AI_VIDEO_BASE_URL=https://seedanceapi.org/v2
DEFAULT_AI_VIDEO_API_KEY=

SENTRY_DSN=

# Swagger docs
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs

# ----- Web (apps/web) -----
# Vite dev/proxy will pick up these from apps/web/.env when running locally.
# Web doesn't need any sensitive keys; everything goes through /api.
