# Megick AI Creations — root .env.example
#
# 这个文件是根目录共享的环境变量示例和兜底配置。
# API 专用配置通常应放在 `apps/api/.env`、`apps/api/.env.development`
# 或 `apps/api/.env.production` 中。
# 启动脚本会显式设置 APP_ENV/NODE_ENV，通常不要在 env 文件里固定 NODE_ENV。

# 可选：应用运行环境；本地开发通常由启动脚本设置为 development。
# APP_ENV=development

# ----- API server (apps/api) -----

# API 服务监听端口；本地常用 3001，部署时可由平台注入。
PORT=3001

# 用于 AES-256-GCM 加密数据库中的第三方密钥；为空时仅适合开发环境。
# 生成方式：openssl rand -base64 32
APP_ENCRYPTION_KEY=

# JWT 会话签名密钥；生产环境必须使用至少 32 字符的随机值。
# 生成方式：openssl rand -base64 32
SESSION_SECRET=

# 浏览器中保存登录态的 Cookie 名称；前后端需保持一致。
SESSION_COOKIE_NAME=mg_session

# 会话 Cookie 作用域；留空表示仅当前主机，跨子域共享时填写 `.example.com`。
SESSION_COOKIE_DOMAIN=

# 会话有效期，单位秒；2592000 秒约等于 30 天。
SESSION_TTL_SECONDS=2592000

# 初始超级管理员邮箱；仅 `pnpm prisma:seed` 初始化数据时使用。
SUPER_ADMIN_EMAIL=administrator@megick.com

# 初始超级管理员密码；仅 `pnpm prisma:seed` 使用，生产环境必须改成强密码。
SUPER_ADMIN_PASSWORD=PleaseChangeMe!2026

# ----- Database / Redis -----

# MySQL 连接串；本地开发数据库配置请优先使用 `apps/api/.env.development.local`。
DATABASE_URL="mysql://root:root@127.0.0.1:3306/megick"

# Redis 主机名或 IP；用于会话缓存、任务队列等后端状态。
REDIS_HOST=127.0.0.1

# Redis 端口；默认 6379。
REDIS_PORT=6379

# Redis 密码；本地无密码时留空。
REDIS_PASSWORD=

# Redis 数据库编号；默认使用 0。
REDIS_DB=0

# ----- Public URLs -----

# Web 前端公开访问地址；用于 OAuth 回跳、邮件/链接生成和跨端跳转。
WEB_BASE_URL=http://localhost:8080

# API 公开访问地址；Swagger server、服务端回调和前端代理会使用。
API_BASE_URL=http://localhost:3333

# 站点 canonical/public origin；Web 构建、站点地图和登录回调可复用。
PUBLIC_BASE_URL=http://localhost:8080

# ----- Aliyun OSS -----

# 阿里云 OSS 区域，例如 oss-cn-shenzhen；默认全局存储桶使用 Aliyun OSS。
OSS_REGION=oss-cn-shenzhen

# 阿里云 OSS AccessKey ID；用于后端上传和签名访问。
OSS_ACCESS_KEY_ID=

# 阿里云 OSS AccessKey Secret；生产环境请只放在部署环境变量中。
OSS_ACCESS_KEY_SECRET=

# 阿里云 OSS Bucket 名称；上传、生成媒体和用户素材默认写入此桶。
OSS_BUCKET=

# OSS 公开访问自定义域名，推荐配置 CDN/自定义域；为空时继续看 OSS_PUBLIC_BASE_URL。
OSS_DOMAIN=

# OSS 公开访问基础地址；OSS_DOMAIN 为空时使用，再为空则回退到 aliyuncs.com。
OSS_PUBLIC_BASE_URL=

# ----- OAuth -----

# Google OAuth Client ID；后台 /admin/oauth-providers 中的配置优先级更高。
GOOGLE_CLIENT_ID=

# Google OAuth Client Secret；生产环境请只放在部署环境变量或后台安全配置中。
GOOGLE_CLIENT_SECRET=

# GitHub OAuth Client ID；后台 /admin/oauth-providers 中的配置优先级更高。
GITHUB_CLIENT_ID=

# GitHub OAuth Client Secret；生产环境请只放在部署环境变量或后台安全配置中。
GITHUB_CLIENT_SECRET=

# ----- Default upstream AI models -----

# 默认文生图上游 BPI 兼容接口地址；seed 和默认模型配置会读取。
BPI_TEXT2IMAGE_BASE_URL=https://bailian.aliyun.cn/v1

# 默认文生图供应商基础地址；后台模型配置为空时作为兜底。
DEFAULT_AI_TEXT2IMAGE_BASE_URL=https://bailian.aliyun.cn/v1

# 默认文生图 API Key；生产环境请放在部署环境变量或后台供应商配置中。
DEFAULT_AI_TEXT2IMAGE_API_KEY=

# 允许直连的文生图上游 origin 列表，多个值可用逗号分隔。
GENERATION_DIRECT_TEXT2IMAGE_ORIGINS=https://bailian.aliyun.cn

# 默认视频生成上游基础地址；seed 和默认视频模型配置会读取。
DEFAULT_AI_VIDEO_BASE_URL=https://byteplus.com/v2

# 默认视频生成 API Key；生产环境请放在部署环境变量或后台供应商配置中。
DEFAULT_AI_VIDEO_API_KEY=

# Sentry DSN；留空表示关闭错误上报。
SENTRY_DSN=

# ----- Swagger docs -----

# 是否启用 Swagger 文档；设置为 false 可关闭。
SWAGGER_ENABLED=true

# Swagger 文档挂载路径；默认 /api/docs。
SWAGGER_PATH=/api/docs

# ----- Web (apps/web) -----

# Web 本地运行时 Vite dev/proxy 会优先读取 apps/web/.env。
# Web 不需要敏感密钥；浏览器侧请求应统一通过 /api 转发。
