PORT=3001
# Scripts set APP_ENV/NODE_ENV explicitly; avoid pinning NODE_ENV in env files.
# APP_ENV=development

# Required: 32-byte base64 secret for AES-256-GCM encrypting third-party secrets at rest
APP_ENCRYPTION_KEY=
# JWT signing secret (>= 32 chars)
SESSION_SECRET=
SESSION_COOKIE_NAME=mg_session
SESSION_COOKIE_DOMAIN=
SESSION_TTL_SECONDS=2592000

# Initial seeded super admin
SUPER_ADMIN_EMAIL=administrator@megick.com
SUPER_ADMIN_PASSWORD=PleaseChangeMe!2026

# Database / Redis
DATABASE_URL="mysql://root:root@127.0.0.1:3306/megick"
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Public URLs
WEB_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:3001
PUBLIC_BASE_URL=http://localhost:8080

# Aliyun OSS (defaults; admin can override per channel)
OSS_REGION=oss-cn-shenzhen
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_PUBLIC_BASE_URL=

# OAuth (fallback; admin /admin/oauth-providers takes precedence)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Upstream AI defaults (admin AIModel rows override)
BPI_TEXT2IMAGE_BASE_URL=https://bpi.crex.cn/v1
DEFAULT_AI_TEXT2IMAGE_BASE_URL=https://bpi.crex.cn/v1
DEFAULT_AI_TEXT2IMAGE_API_KEY=
GENERATION_DIRECT_TEXT2IMAGE_ORIGINS=https://bpi.crex.cn
DEFAULT_AI_VIDEO_BASE_URL=https://seedanceapi.org/v2
DEFAULT_AI_VIDEO_API_KEY=

# Sentry (optional)
SENTRY_DSN=

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs
