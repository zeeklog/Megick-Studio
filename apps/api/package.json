{
  "name": "@megick/api",
  "version": "0.1.0",
  "private": true,
  "description": "Megick AI Creations API server (NestJS)",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "APP_ENV=production NODE_ENV=production node -r ./scripts/load-env.cjs ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "nest start",
    "dev": "APP_ENV=development NODE_ENV=development PORT=3001 API_BASE_URL=http://localhost:3001 WEB_BASE_URL=http://localhost:8080 PUBLIC_BASE_URL=http://localhost:8080 node -r ./scripts/load-env.cjs ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "APP_ENV=development NODE_ENV=development PORT=3001 API_BASE_URL=http://localhost:3001 WEB_BASE_URL=http://localhost:8080 PUBLIC_BASE_URL=http://localhost:8080 node -r ./scripts/load-env.cjs ./node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "APP_ENV=production NODE_ENV=production node -r ./scripts/load-env.cjs dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "prisma:generate": " node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js generate --schema=prisma/schema.prisma",
    "prisma:migrate": "APP_ENV=production NODE_ENV=production node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js migrate deploy --schema=prisma/schema.prisma",
    "prisma:migrate:dev": "APP_ENV=development NODE_ENV=development node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js migrate dev --schema=prisma/schema.prisma",
    "prisma:reset": "APP_ENV=development NODE_ENV=development node -r ./scripts/load-env.cjs ./node_modules/prisma/build/index.js migrate reset --schema=prisma/schema.prisma",
    "prisma:seed": " tsx -r ./scripts/load-env.cjs prisma/seed.ts",
    "openapi:emit": "ts-node -P tsconfig.json --require tsconfig-paths/register scripts/emit-openapi.ts",
    "openapi:emit:dev": "ts-node -P tsconfig.json --require tsconfig-paths/register scripts/emit-openapi.ts",
    "scrape:loova": "ts-node -P tsconfig.json --require tsconfig-paths/register scripts/scrape-loova.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@bull-board/api": "^6.4.4",
    "@bull-board/express": "^6.4.4",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^11.0.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^11.0.6",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.0.6",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.0.7",
    "@nestjs/throttler": "^6.4.0",
    "@prisma/client": "^6.0.1",
    "ali-oss": "^6.21.0",
    "argon2": "^0.41.1",
    "axios": "^1.7.9",
    "bullmq": "^5.34.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "nestjs-pino": "^4.1.0",
    "nestjs-prisma": "^0.24.0",
    "nodemailer": "^6.10.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "raw-body": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "semver": "^7.8.1",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/semver": "^7.7.1",
    "openapi-typescript": "^7.4.4",
    "prisma": "^6.0.1",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
